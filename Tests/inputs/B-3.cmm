int clampAdd(int x, int lim) {
    int y;
    y = x + 3;
    if (y > lim) {
        return lim;
    }
    return y;
}

int main() {
    int buf[5];
    int len;
    int i;
    int prod;
    len = read();
    if (len > 5) {
        len = 5;
    }
    if (len < 1) {
        len = 1;
    }
    i = 0;
    while (i < 5) {
        buf[i] = i + 2;
        i = i + 1;
    }
    i = 0;
    prod = 1;
    while (i < len) {
        buf[i] = clampAdd(buf[i] * 2, 20);
        prod = prod * buf[i];
        i = i + 1;
    }
    write(prod);
    write(buf[len - 1]);
    return 0;
}
