int main() {
    int n;
    int i;
    int j;
    int sum;
    n = read();
    sum = 0;
    i = 1;
    while (i <= n) {
        j = 1;
        while (j <= n) {
            if ((i / 2) * 2 != i) {
                sum = sum + i * j;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    write(sum);
    return 0;
}
