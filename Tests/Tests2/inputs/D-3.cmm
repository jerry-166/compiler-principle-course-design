    struct { int payload_meta_id; float payload_meta_sc; } payload_meta;
};

struct Record {
    int record_nums[4];
    struct {
        int record_det_id;
        float record_det_sc;
    } record_det;
};

struct Record fetch(struct Payload payload_arg) {
    return payload_arg;
}

int main() {
